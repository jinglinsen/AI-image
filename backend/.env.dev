# Flask应用配置
SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# 数据库配置
DATABASE_URL=sqlite:///aigc_assistant.db

# 文件上传配置
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads

# OpenRouter API配置
OPENROUTER_API_KEY=your-openrouter-api-key-here
API_BASE_URL=https://openrouter.ai/api/v1
HTTP_REFERER=https://aigc-assistant.com
X_TITLE=Amazon AIGC Assistant

# Google Generative AI配置
GOOGLE_API_KEY=AIzaSyCezxLyp_DGrBgWlPAweHKLObPzHrtkuvM
GOOGLE_MODEL_NAME=gemini-2.5-flash

# 模型配置
MODEL_NAME=nano-banana/nano-banana
MAX_INPUT_IMAGES=10
DEFAULT_QUALITY=85
API_TIMEOUT=120

# 成本控制
MAX_DAILY_REQUESTS=1000
COST_ALERT_THRESHOLD=100.0

# 日志配置
LOG_LEVEL=INFO