# Flask应用配置
SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# 数据库配置
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/aigc_assistant?charset=utf8mb4

# 文件上传配置
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads

# 阿里云 API配置 (先注释)
# API_BASE_URL=
# API_KEY=

# AIHubMix API配置 (先注释)
# API_BASE_URL=https://aihubmix.com/v1
# API_KEY=

# DMX API配置
API_BASE_URL=https://www.dmxapi.cn/v1
API_KEY=

# 模型配置
FAST_MODEL_NAME=dall-e-3
VISION_MODEL_NAME=dall-e-3
MAX_INPUT_IMAGES=10
DEFAULT_QUALITY=85
API_TIMEOUT=120

# 成本控制
MAX_DAILY_REQUESTS=1000
COST_ALERT_THRESHOLD=100.0

# 日志配置
LOG_LEVEL=INFO

# 存储配置
OSS_ENABLED=False
